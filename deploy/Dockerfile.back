# back: the API only — no static files, no Playwright. Bank syncs are
# delegated to the sync service via MONORI_SYNC_URL.
FROM python:3.12-slim
WORKDIR /app
COPY server/pyproject.toml ./
RUN pip install --no-cache-dir "uv==0.11.26" && uv pip install --system -r pyproject.toml
COPY server/app ./app
COPY server/schema.sql ./schema.sql
COPY server/migrations ./migrations
ENV MONORI_DB=/app/data/monori.db
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
